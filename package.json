{
  "name": "mistral-resume-analyser-monorepo",
  "private": true,
  "version": "1.0.4",
  "description": "AI Resume Analyzer web and desktop application",
  "author": "NxtWave",
  "repository": {
    "type": "git",
    "url": "https://github.com/kellatirupathi/ResumePBS.git"
  },
  "main": "desktop/main.cjs",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "typecheck": "npm run typecheck --workspace server && npm run typecheck --workspace client",
    "desktop:prepare-env": "node desktop/prepare-env.cjs",
    "desktop:dev": "npm run desktop:prepare-env && npm run build && node desktop/run-electron.cjs",
    "desktop:dist": "npm run desktop:prepare-env && npm run build && electron-builder --win nsis",
    "desktop:portable": "npm run desktop:prepare-env && npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.80",
    "axios": "^1.12.2",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.3.9",
    "express": "^5.1.0",
    "file-type": "^21.0.0",
    "form-data": "^4.0.4",
    "googleapis": "^156.0.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.4.296",
    "tesseract.js": "^6.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^36.9.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.nxtwave.airesumeanalyzer",
    "productName": "AI Resume Analyzer",
    "artifactName": "AI-Resume-Analyzer-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "client/dist/**/*",
      "server/dist/**/*",
      "server/resources/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "desktop/.env.runtime",
        "to": ".env"
      }
    ],
    "asarUnpack": [
      "node_modules/@napi-rs/**/*",
      "node_modules/tesseract.js-core/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kellatirupathi",
        "repo": "ResumePBS"
      }
    ]
  }
}
